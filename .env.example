VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Weekly digest: fill these, then run `npm run analytics:digest` (loads `.env` automatically).
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_PROJECT_ID=
# POSTHOG_HOST=https://us.i.posthog.com
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: PostHog while npm run dev (default off).
# VITE_ANALYTICS_DEV=true
